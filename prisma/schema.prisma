generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Cliente {
  id        String   @id @default(cuid())
  nombre    String
  telefono  String
  direccion String?
  notas     String?
  createdAt DateTime @default(now())

  ventas Venta[]
}

model Producto {
  id                   String   @id @default(cuid())
  nombre               String
  descripcion          String?
  marca                String
  tipoElectrodomestico String
  modelo               String
  codigoInterno        String   @unique
  costoProveedor       Float
  precioReferencia     Float?
  proveedorHabitual    String?
  createdAt            DateTime @default(now())
  lastModified         DateTime @updatedAt

  ventaItems VentaItem[]
}

model Venta {
  id           String    @id @default(cuid())
  clienteId    String
  estado       String    @default("PRESUPUESTO")
  total        Float
  costoEnvio   Float?
  tipoEntrega  String
  fechaEntrega DateTime?
  notas        String?
  createdAt    DateTime  @default(now())

  cliente Cliente     @relation(fields: [clienteId], references: [id])
  items   VentaItem[]
  pagos   Pago[]
}

model VentaItem {
  id                    String    @id @default(cuid())
  ventaId               String
  productoId            String
  cantidad              Int
  precioUnitario        Float
  proveedorEstado       String    @default("NO_PEDIDO")
  codigoPedido          String?
  fechaPedidoProveedor  DateTime?
  fechaLlegadaProveedor DateTime?

  venta    Venta    @relation(fields: [ventaId], references: [id], onDelete: Cascade)
  producto Producto @relation(fields: [productoId], references: [id])
}

model Pago {
  id      String   @id @default(cuid())
  ventaId String
  monto   Float
  tipo    String
  fecha   DateTime @default(now())

  venta Venta @relation(fields: [ventaId], references: [id], onDelete: Cascade)
}